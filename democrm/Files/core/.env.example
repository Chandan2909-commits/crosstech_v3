APP_NAME=CrossFlow
APP_ENV=production
APP_KEY=base64:REPLACE_WITH_YOUR_APP_KEY
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://democrm.crosstechsolutions.in

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

# ─── Vercel ──────────────────────────────────────────────────────────────────
# Set VERCEL=1 in Vercel dashboard → Environment Variables
VERCEL=1

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ─── Database (Railway MySQL) ─────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=REPLACE_WITH_RAILWAY_HOST
DB_PORT=REPLACE_WITH_RAILWAY_PORT
DB_DATABASE=railway
DB_USERNAME=root
DB_PASSWORD=REPLACE_WITH_RAILWAY_PASSWORD

# ─── Session / Cache / Queue ──────────────────────────────────────────────────
# Must use 'database' driver on Vercel (no persistent filesystem)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=database
CACHE_PREFIX=

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@crossflow.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
