{
  "version": 2,
  "buildCommand": "composer install --no-dev --optimize-autoloader --working-dir=api",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.4"
    }
  },
  "routes": [
    {
      "src": "^/assets/(.*)",
      "dest": "/Files/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
