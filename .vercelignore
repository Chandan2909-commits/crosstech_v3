# Vercel ignore — keeps the upload lean
vendor/
democrm/Files/core/vendor/

# Runtime storage (generated on /tmp at runtime)
democrm/Files/core/storage/framework/sessions/*
democrm/Files/core/storage/framework/views/*
democrm/Files/core/storage/framework/cache/data/*
democrm/Files/core/storage/logs/

# Secrets
democrm/Files/core/.env
democrm/Files/core/.env.backup

# IDE
.vs/
.vscode/
.idea/

# Node
node_modules/

# Documentation assets (large, not needed for runtime)
democrm/Documentation/

# Vercel local files
.vercel/
.env.local
